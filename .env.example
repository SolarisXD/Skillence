# Environment Configuration Template
# Copy this file to .env and fill in actual values for local development
# DO NOT commit .env to version control

# === DATABASE ===
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillence_db?retryWrites=true&w=majority

# === AUTHENTICATION ===
SECRET_KEY=your-super-secret-jwt-key-min-32-chars-long-for-hs256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === AZURE SERVICES ===
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_API_KEY=your-azure-document-intelligence-api-key
DOC_INTEL_API=your-azure-document-intelligence-api-key-alternative

# === AI/LLM SERVICES ===
GEMINI_API=your-google-gemini-api-key
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash

# === THIRD-PARTY APIs ===
ONET_API_KEY=your-onet-api-key
JSEARCH_API_KEY=your-jsearch-api-key

# === FRONTEND ===
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# === EMAIL ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
# Note: For Gmail, use "App Passwords" feature, not your main password

# === DEPLOYMENT ===
# Uncomment and set when deploying to production
# RENDER_DEPLOYMENT_ID=your-render-deployment-id
# LOG_LEVEL=info

# === LOCAL DEVELOPMENT FLAGS (Optional) ===
# DEBUG=true
# RELOAD_ON_CHANGE=true
